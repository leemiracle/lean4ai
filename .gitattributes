# Auto detect text files and perform LF normalization
* text=auto

# Markdown files
*.md text eol=lf

# Lean4 source files
*.lean text eol=lf

# Python files
*.py text eol=lf

# Shell scripts
*.sh text eol=lf

# JSON files
*.json text eol=lf

# YAML files
*.yml text eol=lf
*.yaml text eol=lf

# TOML files
*.toml text eol=lf

# Binary files
*.png binary
*.jpg binary
*.jpeg binary
*.gif binary
*.pdf binary
*.zip binary
*.tar.gz binary
